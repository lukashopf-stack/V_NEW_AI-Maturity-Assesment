let state = { profiles:[] };
let activeProfileId = null;

function initSupabase() {
  supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
}

async function loadData() {
  try {
    const { data, error } = await supabase
      .from('profiles')
      .select('*')
      .order('created_at', { ascending: false });
    
    if (error) throw error;
    
    state.profiles = data || [];
  } catch(e) {
    console.error('Load error:', e);
  }
}

async function saveProfile(profile) {
  try {
    const { data, error } = await supabase
      .from('profiles')
      .upsert(profile)
      .select();
    
    if (error) throw error;
    
    return data[0];
  } catch(e) {
    console.error('Save error:', e);
    return null;
  }
}

async function deleteAllProfiles() {
  try {
    const { error } = await supabase
      .from('profiles')
      .delete()
      .neq('id', '');
    
    if (error) throw error;
  } catch(e) {
    console.error('Delete error:', e);
  }
}

function handleLogin() {
  const user = document.getElementById('login-user').value;
  const pass = document.getElementById('login-pass').value;
  const error = document.getElementById('login-error');
  
  if ((user === ADMIN_USER && pass === ADMIN_PASS) || (user === GUEST_USER && pass === GUEST_PASS)) {
    userRole = user === ADMIN_USER ? 'admin' : 'guest';
    error.classList.remove('show');
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('app-root').classList.remove('hidden');
    
    initSupabase();
    loadData().then(renderHome);
  } else {
    error.classList.add('show');
  }
}

function setLang(l) {
  lang = l;
  document.querySelectorAll('[data-en]').forEach(el => {
    el.textContent = l === 'en' ? el.dataset.en : el.dataset.de;
  });
  document.querySelectorAll('.lang-btn').forEach(btn => {
    btn.classList.toggle('active', btn.id.includes(l));
  });
}

function renderHome() {
  if (userRole === 'admin') {
    document.getElementById('admin-section').style.display = 'block';
    document.getElementById('guest-section').style.display = 'none';
    renderAdminList();
  } else {
    document.getElementById('admin-section').style.display = 'none';
    document.getElementById('guest-section').style.display = 'block';
  }
}

function renderAdminList() {
  const list = document.getElementById('admin-list');
  list.innerHTML = '';
  
  const container = document.createElement('div');
  container.className = 'respondent-list';
  
  state.profiles.forEach(p => {
    const answered = QS.filter(q => p.responses && p.responses[q.id]).length;
    const isComplete = answered === QS.length;
    
    const item = document.createElement('div');
    item.className = 'respondent-item';
    item.onclick = () => openSurvey(p.id);
    
    item.innerHTML = `
      <div class="respondent-name">${p.name}</div>
      <div class="respondent-role">${p.role || t('noRoleSpec')}</div>
      <span class="respondent-status ${isComplete ? 'status-complete' : answered > 0 ? 'status-partial' : 'status-empty'}">
        ${isComplete ? t('complete') : answered > 0 ? `${answered}/25` : t('notStarted')}
      </span>
    `;
    
    container.appendChild(item);
  });
  
  list.appendChild(container);
}

function startGuestSurvey() {
  const name = document.getElementById('guest-name').value.trim();
  const role = document.getElementById('guest-role').value.trim();
  
  if (!name) {
    document.getElementById('guest-name').focus();
    return;
  }
  
  const id = 'p' + Date.now();
  const profile = { 
    id, 
    name, 
    role, 
    responses: {}, 
    user_id: GUEST_USER, 
    created_at: new Date().toISOString() 
  };
  
  saveProfile(profile).then(savedProfile => {
    if (savedProfile) {
      state.profiles.unshift(savedProfile);
      currentUserId = id;
      openSurvey(id);
    }
  });
}

function openSurvey(pid) {
  activeProfileId = pid;
  const p = state.profiles.find(p => p.id === pid);
  
  if (!p) return;
  
  if (userRole === 'guest' && p.user_id !== GUEST_USER && currentUserId !== pid) {
    alert('Access denied');
    return;
  }
  
  document.getElementById('survey-who').textContent = p.name;
  document.getElementById('survey-org').textContent = p.role || t('noRoleSpec');
  
  renderSurvey(p);
  showScreen('survey');
}

function renderSurvey(p) {
  const body = document.getElementById('survey-body');
  body.innerHTML = '';
  
  CAP.forEach(cap => {
    const section = document.createElement('div');
    section.className = 'cap-section';
    
    const header = document.createElement('div');
    header.className = 'cap-header';
    header.textContent = l(cap.name);
    section.appendChild(header);
    
    QS.filter(q => q.c === cap.id).forEach(q => {
      const ln = LENS.find(lens => lens.id === q.l);
      const cur = p.responses ? p.responses[q.id] : null;
      const opts = q.opts[lang];
      
      const qDiv = document.createElement('div');
      qDiv.className = 'question';
      
      const qHeader = document.createElement('div');
      qHeader.className = 'question-header';
      
      const lensTag = document.createElement('div');
      lensTag.className = 'question-lens';
      lensTag.style.background = ln.color + '22';
      lensTag.style.color = ln.color;
      lensTag.textContent = l(ln.name);
      qHeader.appendChild(lensTag);
      
      const qText = document.createElement('div');
      qText.className = 'question-text';
      qText.textContent = l(q.text);
      qHeader.appendChild(qText);
      
      const qDesc = document.createElement('div');
      qDesc.className = 'question-desc';
      qDesc.textContent = l(q.desc);
      qHeader.appendChild(qDesc);
      
      qDiv.appendChild(qHeader);
      
      const optionsDiv = document.createElement('div');
      optionsDiv.className = 'options';
      optionsDiv.id = 'opts_' + q.id;
      
      opts.forEach(opt => {
        const btn = document.createElement('button');
        btn.className = 'option' + (cur === opt ? ' selected' : '');
        btn.textContent = opt;
        btn.onclick = () => pick(q.id, opt);
        optionsDiv.appendChild(btn);
      });
      
      const unableBtn = document.createElement('button');
      unableBtn.className = 'option unable' + (cur === 'unable' ? ' selected' : '');
      unableBtn.textContent = t('unable');
      unableBtn.onclick = () => pick(q.id, 'unable');
      optionsDiv.appendChild(unableBtn);
      
      qDiv.appendChild(optionsDiv);
      section.appendChild(qDiv);
    });
    
    body.appendChild(section);
  });
  
  updateProgress(p);
}

function pick(qid, val) {
  const p = state.profiles.find(p => p.id === activeProfileId);
  if (!p) return;
  
  if (!p.responses) p.responses = {};
  p.responses[qid] = val;
  
  const optsDiv = document.getElementById('opts_' + qid);
  if (optsDiv) {
    optsDiv.querySelectorAll('.option').forEach(btn => {
      btn.classList.remove('selected');
      if (btn.textContent === val || (val === 'unable' && btn.classList.contains('unable'))) {
        btn.classList.add('selected');
      }
    });
  }
  
  updateProgress(p);
}

function updateProgress(p) {
  const answered = QS.filter(q => p.responses && p.responses[q.id]).length;
  const total = QS.length;
  
  document.getElementById('prog-fill').style.width = Math.round(answered / total * 100) + '%';
  document.getElementById('prog-label').textContent = answered + ' / ' + total;
}

function completeSurvey() {
  const p = state.profiles.find(p => p.id === activeProfileId);
  if (p) {
    saveProfile(p).then(() => {
      goHome();
    });
  }
}

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + id).classList.add('active');
}

function goHome() {
  loadData().then(renderHome);
  showScreen('home');
}

function showResults() {
  alert('Results view coming soon');
}

function exportData() {
  const blob = new Blob([JSON.stringify(state, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'arcmm_data_' + new Date().toISOString().slice(0, 10) + '.json';
  a.click();
}

function resetAll() {
  if (!confirm(lang === 'en' ? 'Reset all data?' : 'Alle Daten zurücksetzen?')) return;
  
  deleteAllProfiles().then(() => {
    state = { profiles: [] };
    renderHome();
  });
}

document.getElementById('login-user').addEventListener('keydown', e => {
  if (e.key === 'Enter') handleLogin();
});

document.getElementById('login-pass').addEventListener('keydown', e => {
  if (e.key === 'Enter') handleLogin();
});
</script>
</body>
</html>
